# Copy this file to .env and fill in your values

# Anthropic Claude API Key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Claude models to use
MODEL=anthropic/claude-sonnet-4-6
PRESENTER_MODEL=anthropic/claude-haiku-4-5

# Serper.dev — Google search for agents — https://serper.dev
SERPER_API_KEY=

# Tavily — AI research search (optional) — https://tavily.com
TAVILY_API_KEY=
